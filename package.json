{
  "name": "rclone-size-ui",
  "version": "0.0.0",
  "type": "commonjs",
  "description": "A simple web app to explore the size of files and directories in a rclone remote.",
  "keywords": [],
  "author": "Beeno Tung <aabbcc1241@yahoo.com.hk> (https://beeno-tung.surge.sh)",
  "license": "BSD-2-Clause",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "tsc --noEmit",
    "clean": "rimraf dist",
    "build": "esbuild --bundle src/app.ts --outfile=dist/bundle.js",
    "tsc": "tsc -p .",
    "dev": "npm run build -- --watch"
  },
  "devDependencies": {
    "@types/node": "^24.13.0",
    "esbuild": "^0.28.0",
    "rimraf": "^6.1.3",
    "surge": "^0.27.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beenotung/rclone-size-ui.git"
  },
  "bugs": {
    "url": "https://github.com/beenotung/rclone-size-ui/issues"
  },
  "homepage": "https://github.com/beenotung/rclone-size-ui#readme"
}
